ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
POSTGRES_PASSWORD=your_local_postgres_password
LLM_PROVIDER=claude
DATA_SOURCE=mock
TENANT_SLUG=fotopia
DOCUMENTS_DIR=/app/documents
TEMPLATES_DIR=/app/templates
TENANT_CONFIG_DIR=/app/tenant_config

# Leave feature — identity switch for demo (no JWT yet)
# Set to "employee" to test leave submission as EMP001 (Saif); default is "hr_manager" (Nourhan)
DEMO_ROLE=hr_manager

# Environment fencing — required when DEBUG_ALLOW_DEMO_ROLE=True
APP_ENV=local                  # "local" | "dev" | "staging" | "prod"
DEBUG_ALLOW_DEMO_ROLE=false    # Never True outside local/dev; startup guard enforces this

# JWT secret — change before any real deployment
JWT_SECRET=dev-secret-change-before-production

# Azure Communication Services — leave approval emails
# Leave blank in dev to use mock mode (email content logged to console instead of sent)
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_SENDER_EMAIL=hr-agent@fotopia.ai
API_BASE_URL=http://localhost:8000
